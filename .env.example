GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GH_USERNAME=your-github-username
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ========== Site Configuration ==========
# Comma-separated BCP 47 language codes. First item is the default language.
# "en" is the built-in base/fallback language. Examples: en | zh-CN | en,zh-CN
SITE_LANGUAGES=en

# Custom site title (optional, JSON keyed by language code, empty = use built-in)
# Example: {"en":"My Stars","zh-CN":"我的星标"}
SITE_TITLE=
SITE_SUBTITLE=

# ========== AI Features ==========
# Toggle AI features: "on" enables AI intros and note translation,
# "off" disables AI and falls back to the original GitHub description.
AI_ENABLED=on

# ========== Cloudflare D1 (optional) ==========
# External persistent cache for AI summaries. If set, the build pipeline
# reads/writes cache from D1 instead of local summaries.json file.
# Useful when CI workspace has no local cache across builds.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
D1_DATABASE_ID=
