GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GH_USERNAME=your-github-username
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ========== Deploy Schedule ==========
# How often to refresh data from GitHub (in days). Default: 1 (daily).
# Set to 7 for weekly, 30 for monthly, etc. Only affects scheduled runs;
# manual triggers and pushes to main always deploy.
# REFRESH_DAYS=1

# ========== Site Configuration ==========
# Comma-separated BCP 47 language codes. First item is the default language.
# "en" is the built-in base/fallback language. Examples: en | zh-CN | en,zh-CN
# NOTE: Each additional language triggers extra AI API calls (intros + translations),
# significantly increasing build time and cost. Only keep languages you actually need.
SITE_LANGUAGES=en

# Custom site title (optional, JSON keyed by language code, empty = use built-in)
# Example: {"en":"My Stars","zh-CN":"我的星标"}
SITE_TITLE=
SITE_SUBTITLE=

# Project URL shown in the footer (optional, defaults to gh-starboard repo)
# PROJECT_URL=https://github.com/your-user/your-repo

# ========== AI Features ==========
# Toggle AI features: "on" enables AI intros and note translation,
# "off" disables AI and falls back to the original GitHub description.
AI_ENABLED=on

# Auto-categorize uncategorized repos using AI. Default: off.
# Set to "on" to let AI assign categories based on repo metadata.
# Incremental: only categorizes new/changed repos, preserves existing.
AI_AUTO_CATEGORY=

# Concurrent AI requests (default: 3). Lower values reduce API rate limits.
# AI_CONCURRENCY=3

# ========== Cloudflare D1 (optional) ==========
# External persistent cache for AI summaries. If set, the build pipeline
# reads/writes cache from D1 instead of local summaries.json file.
# Useful when CI workspace has no local cache across builds.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
D1_DATABASE_ID=
